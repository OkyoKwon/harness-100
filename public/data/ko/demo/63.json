{
  "id": "research-assistant-demo",
  "title": "Research Assistant",
  "userPrompt": "논문 조사해줘",
  "steps": [
    {
      "agentId": "literature-searcher",
      "action": "문헌 검색 전문가.",
      "durationMs": 3600,
      "toolsUsed": [
        "WebSearch",
        "WebFetch",
        "Read"
      ],
      "output": {
        "title": "문헌 검색 결과",
        "snippet": "# 문헌 검색 결과\n\n## 검색 전략\n- **연구 질문**: [구체적 연구 질문]\n- **핵심 키워드**: [keyword1, keyword2, ...]"
      }
    },
    {
      "agentId": "note-taker",
      "action": "메모 작성 전문가.",
      "durationMs": 3200,
      "toolsUsed": [
        "WebFetch",
        "Write",
        "Read"
      ],
      "output": {
        "title": "읽기 메모",
        "snippet": "# 읽기 메모\n\n## 문헌 1: [저자 (연도)] — [제목]\n\n### 서지 정보"
      }
    },
    {
      "agentId": "reference-manager",
      "action": "참고문헌 관리 전문가.",
      "durationMs": 2800,
      "toolsUsed": [
        "Write",
        "Read"
      ],
      "output": {
        "title": "참고문헌 목록",
        "snippet": "# 참고문헌 목록\n\n## 인용 형식: [APA 7th / MLA 9th / Chicago / ...]\n\n## 참고문헌 (References)"
      }
    },
    {
      "agentId": "critic-synthesizer",
      "action": "비평·종합 전문가.",
      "durationMs": 2800,
      "toolsUsed": [
        "Write",
        "Read"
      ],
      "output": {
        "title": "비평·종합 분석서",
        "snippet": "# 비평·종합 분석서\n\n## 종합 개요\n- **연구 주제**: [주제]\n- **분석 문헌 수**: [N편]"
      }
    },
    {
      "agentId": "research-coordinator",
      "action": "연구 조율자(QA).",
      "durationMs": 3200,
      "toolsUsed": [
        "SendMessage",
        "Write",
        "Read"
      ],
      "output": {
        "title": "연구 조율 보고서",
        "snippet": "# 연구 조율 보고서\n\n## 종합 평가\n- **연구 보조 완성도**: 🟢 완료 / 🟡 보완 필요 / 🔴 재작업 필요\n- **총평**: [1~2문장 요약]"
      }
    }
  ]
}
